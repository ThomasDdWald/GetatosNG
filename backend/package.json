{
  "name": "getatos-safari-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "Backend API for GeTaToS Safari Website",
  "main": "dist/index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "node --import tsx src/index.ts",
    "build": "tsc",
    "start": "node server.js",
    "server": "node server.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "ts-node prisma/seed.ts",
    "db:seed:sql": "ts-node prisma/seed-sql.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@google-cloud/recaptcha-enterprise": "^6.4.0",
    "@google-cloud/storage": "^7.7.0",
    "@prisma/client": "^5.7.1",
    "@sendgrid/mail": "^8.1.0",
    "axios": "^1.13.6",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "firebase-admin": "^13.8.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "otplib": "^13.4.0",
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0",
    "uuid": "^13.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.10.5",
    "@types/qrcode": "^1.5.6",
    "@types/uuid": "^10.0.0",
    "@types/speakeasy": "^2.0.10",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  }
}
