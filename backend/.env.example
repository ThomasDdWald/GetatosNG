# Server
PORT=4000

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/getatos_safari"

# Security - IMPORTANT: Change these for production!
JWT_SECRET="change-this-to-a-secure-random-string"
ADMIN_EMAIL="admin@yourdomain.com"
ADMIN_PASSWORD="change-this-to-a-secure-password"

# reCAPTCHA Configuration
# Get your keys from: https://www.google.com/recaptcha/admin
# Site Key (Frontend): Add to frontend .env as VITE_RECAPTCHA_SITE_KEY
RECAPTCHA_SECRET_KEY=""

# DPO Payment Gateway (optional)
DPO_SERVICE_TYPE=""
DPO_DEFAULT_CURRENCY="USD"
DPO_COMPANY_TOKEN=""
